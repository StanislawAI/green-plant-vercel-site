{
    "rewrites": [
        {
            "source": "/presentation",
            "destination": "/presentation.html"
        },
        {
            "source": "/presentation/",
            "destination": "/presentation.html"
        },
        {
            "source": "/presentations",
            "destination": "/presentation.html"
        },
        {
            "source": "/presentations/",
            "destination": "/presentation.html"
        },
        {
            "source": "/((?!presentation.html|assets|fonts|favicon).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                }
            ]
        },
        {
            "source": "/presentation.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/fonts/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
